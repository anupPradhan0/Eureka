# Copy to .env and fill in real values. Never commit .env.

# --- Server ---
APP_NAME=Eureka
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Comma-separated list of allowed frontend origins (CORS).
ALLOWED_ORIGINS=http://localhost:5173

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=eureka

# --- Auth / JWT ---
# Generate a strong secret, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# --- Encryption (BYO API keys / tokens at rest) ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-a-real-fernet-key

# --- Outbound HTTP timeouts (seconds) ---
AI_HTTP_TIMEOUT_SECONDS=15
GITHUB_HTTP_TIMEOUT_SECONDS=20
GITHUB_TREE_MAX_ENTRIES=5000
README_MAX_CHARS=50000
